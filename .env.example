# PostgreSQL
DATABASE_URL=postgresql+asyncpg://lyrasync:lyrasync@postgres:5432/lyrasync

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=lyrasync

# Genius API — получить на https://genius.com/api-clients
GENIUS_TOKEN=your_genius_token_here

# Whisper
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda

# Limits
MAX_FILE_SIZE_MB=50
MAX_DURATION_SEC=900
RATE_LIMIT_PER_MINUTE=10
